# Server
QWABLE_HOST=127.0.0.1
QWABLE_PORT=8088
QWABLE_DEFAULT_PROFILE=fast-agent
QWABLE_TIMEOUT_SECONDS=900
QWABLE_QUEUE_TIMEOUT_SECONDS=5
QWABLE_MAX_CONCURRENT_REQUESTS=1

# Local model backend
# Historical env name kept for compatibility: OLLAMA_BASE_URL is now the
# OpenAI-compatible local backend URL. Gate G09 uses LM Studio models from
# ~/.lmstudio/hub/models instead of Ollama model tags.
LOCAL_MODEL_BACKEND=lmstudio
OLLAMA_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_CLI_PATH=$HOME/.lmstudio/bin/lms

# ds4
DS4_BASE_URL=http://127.0.0.1:8000/v1
DS4_MODEL=deepseek-v4-flash
DS4_TIMEOUT_SECONDS=1200
DS4_MAX_INPUT_CHARS=160000
DS4_MAX_CONCURRENT_REQUESTS=1

# LM Studio model ids
MODEL_FAST=google/gemma-4-26b-a4b-qat
MODEL_CODER=qwen/qwen3-coder-next
MODEL_TOOLER=qwen/qwen3-coder-next
MODEL_CRITIC=deepseek-r1-distill-qwen-32b
MODEL_JUDGE=deepseek-r1-distill-qwen-32b
MODEL_FORMATTER=google/gemma-4-26b-a4b-qat
MODEL_VISION_FAST=google/gemma-4-26b-a4b-qat
MODEL_VISION_PRO=qwen/qwen3-vl-30b
MODEL_VISION_PRO_FALLBACK=
MODEL_AGENTIC_PRO=qwen/qwen3.6-35b-a3b
MODEL_HERMES_PRO=qwen/qwen3.6-35b-a3b
MODEL_AGENTIC_MLX=qwen/qwen3.6-35b-a3b
MODEL_FORMATTER_MLX=google/gemma-4-26b-a4b-qat
MODEL_HEAVY=deepseek-v4-flash

# G10 Fusion deliberation router
FUSION_DEFAULT_PRESET=quality
FUSION_MAX_TOKENS_PANEL=1500
FUSION_MAX_TOKENS_JUDGE=3600

# G11 MLX formatter preference
# When true (default), fast-agent profile auto-routes SHORT text-only requests
# (< QWABLE_MLX_FORMATTER_MAX_CHARS chars, no tool calls) through
# formatter-mlx (gemma via MLX, ~16GB) instead of fast-agent (qwen3.6, 38GB).
# Saves ~30s model-load time for trivial text work.
QWABLE_PREFER_MLX_FORMATTER=true
QWABLE_MLX_FORMATTER_MAX_CHARS=1000

# G12 micro B: warmup scripts (launchd RunAtLoad) skip if false
QWABLE_WARMUP_ON_BOOT=true

# Agent runtime
AGENT_RUNTIME_ENABLED=true
AGENT_STORE_PATH=.qwable_agent_runs.sqlite3
AGENT_MAX_STEPS=12
AGENT_MAX_TOOL_CALLS=40
AGENT_MAX_REPAIR_ATTEMPTS=3
AGENT_MAX_RUNTIME_SECONDS=1800
AGENT_ENABLE_CONTEXT_COMPACTION=true
AGENT_CONTEXT_PACK_MAX_CHARS=64000
AGENT_REPO_INDEX_MAX_FILES=300
AGENT_TRACE_ENABLED=true
AGENT_REPLAY_ENABLED=true

# Workflow context limits
AGENTIC_WORKFLOW_MAX_INPUT_CHARS=256000
CODING_WORKFLOW_MAX_INPUT_CHARS=256000
REVIEW_WORKFLOW_MAX_INPUT_CHARS=160000

# Agent model roles
MODEL_ROLE_SIMPLE_FORMATTER=google/gemma-4-26b-a4b-qat
MODEL_ROLE_PLANNER=qwen/qwen3.6-35b-a3b
MODEL_ROLE_EXECUTOR=qwen/qwen3-coder-next
MODEL_ROLE_REPAIR=qwen/qwen3-coder-next
MODEL_ROLE_CRITIC=deepseek-r1-distill-qwen-32b
MODEL_ROLE_JUDGE=qwen/qwen3.6-35b-a3b
MODEL_ROLE_HEAVY_PRIMARY=deepseek-v4-flash
MODEL_ROLE_VISION=qwen/qwen3-vl-30b
MODEL_ROLE_PLANNER_FALLBACK_CHAIN=qwen/qwen3.6-35b-a3b,qwen/qwen3-coder-next,google/gemma-4-26b-a4b-qat
MODEL_ROLE_EXECUTOR_FALLBACK_CHAIN=qwen/qwen3-coder-next,qwen/qwen3.6-35b-a3b
MODEL_ROLE_REPAIR_FALLBACK_CHAIN=qwen/qwen3-coder-next,qwen/qwen3.6-35b-a3b
MODEL_ROLE_CRITIC_FALLBACK_CHAIN=deepseek-r1-distill-qwen-32b,qwen/qwen3.6-35b-a3b,google/gemma-4-26b-a4b-qat
MODEL_ROLE_JUDGE_FALLBACK_CHAIN=qwen/qwen3.6-35b-a3b,deepseek-r1-distill-qwen-32b,google/gemma-4-26b-a4b-qat

# M5 resource estimates from `lms ls` / LM Studio model sizes
M5_UNIFIED_MEMORY_GB=128
M5_RESERVED_MEMORY_GB=28
M5_ALLOW_FULL_PARALLEL=false
M5_KV_CACHE_RESERVE_GB_PER_PARALLEL_MODEL=5

EST_MODEL_FAST_GB=16
EST_MODEL_CODER_GB=65
EST_MODEL_TOOLER_GB=65
EST_MODEL_CRITIC_GB=66
EST_MODEL_JUDGE_GB=66
EST_MODEL_FORMATTER_GB=16
EST_MODEL_VISION_FAST_GB=16
EST_MODEL_VISION_PRO_GB=34
EST_MODEL_AGENTIC_PRO_GB=38
EST_MODEL_HERMES_PRO_GB=38
EST_MODEL_AGENTIC_MLX_GB=38
EST_MODEL_FORMATTER_MLX_GB=16
EST_MODEL_HEAVY_GB=90

# Context / output
FAST_MAX_INPUT_CHARS=24000
FULL_MAX_INPUT_CHARS=96000
HEAVY_MAX_INPUT_CHARS=160000
AGENTIC_MLX_MAX_INPUT_CHARS=256000
# Generous default for clients that forget max_tokens; also safe when a
# reasoning model is temporarily selected for targeted probes.
FAST_MAX_TOKENS=1500
FULL_PANEL_MAX_TOKENS=1800
FULL_JUDGE_MAX_TOKENS=3600
HEAVY_MAX_TOKENS=3600
AGENTIC_MLX_MAX_TOKENS=600
VISION_MAX_TOKENS=1600
VISION_MAX_IMAGES=8
VISION_MAX_IMAGE_MB=16
VISION_FAST_MAX_INPUT_CHARS=24000
VISION_PRO_MAX_INPUT_CHARS=96000

# Streaming
STREAM_KEEPALIVE_SECONDS=10
STREAM_CHUNK_CHARS=1000

# --------------------------------------------------
# v1.8 optional Fable/Mythos-style local models
# --------------------------------------------------

# Qwable: Fable-style coding executor / repair worker
ENABLE_QWABLE_EXECUTOR=true
MODEL_QWABLE=qwable-9b-claude-fable-5-q6k
MODEL_QWABLE_RUNTIME=lmstudio
MODEL_QWABLE_CONTEXT_LIMIT=32768
MODEL_QWABLE_TEMPERATURE=0.25
MODEL_QWABLE_TOP_P=0.9
MODEL_QWABLE_REPEAT_PENALTY=1.05

# Qwythos: Mythos-style long-context worker (default OFF — opt-in)
ENABLE_QWYTHOS_LONG_CONTEXT=false
MODEL_QWYTHOS=qwythos-9b-claude-mythos-5-1m
MODEL_QWYTHOS_RUNTIME=lmstudio
MODEL_QWYTHOS_CONTEXT_LIMIT=65536
MODEL_QWYTHOS_MAX_CONTEXT_LIMIT=131072
MODEL_QWYTHOS_TEMPERATURE=0.6
MODEL_QWYTHOS_TOP_P=0.95
MODEL_QWYTHOS_TOP_K=20
MODEL_QWYTHOS_REPEAT_PENALTY=1.05

# Fallback safety
ENABLE_EXECUTOR_FALLBACK=true
ENABLE_REPAIR_FALLBACK=true
ENABLE_LONG_CONTEXT_FALLBACK=true

# Model health check behavior
MODEL_HEALTH_CHECK_ON_STARTUP=false
MODEL_HEALTH_CHECK_TIMEOUT_SECONDS=30

# Local helper script defaults
DS4_DIR=$HOME/Documents/ds4
DS4_KV_DIR=$HOME/Documents/ds4-kv
DS4_CTX=100000
DS4_KV_DISK_SPACE_MB=32768
